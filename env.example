# Database Configuration
# Options: sqlite, postgresql, dynamodb
DATABASE_TYPE=sqlite

# Set to true to migrate data from DynamoDB to PostgreSQL when starting in PostgreSQL mode
MIGRATE_FROM_DYNAMODB=false

# SQLite Configuration (used if DATABASE_TYPE=sqlite)
SQLITE_DB_PATH=./payroll.db

# PostgreSQL Configuration (when DATABASE_TYPE=postgresql)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=payrollsmith_gh
DB_USER=postgres
DB_PASSWORD=your_password

# AWS Configuration (required when DATABASE_TYPE=dynamodb)
AWS_ACCESS_KEY_ID=your-access-key-id-here
AWS_SECRET_ACCESS_KEY=your-secret-access-key-here
AWS_REGION=us-east-1

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server Configuration
PORT=5173
NODE_ENV=development

# Ghana Tax Rates (2024)
SSNIT_RATE=0.055
NHIL_RATE=0.025

# Email Configuration (for sending payslips)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password